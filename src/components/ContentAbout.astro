---
/**
 * ContentAbout.astro — Tab "about.ts": Skill Rico sebagai kode TypeScript
 *
 * Menampilkan profil dan skill Rico dalam format kode TypeScript,
 * di-render dengan syntax highlighting Shiki (warna otomatis seperti di VS Code).
 *
 * Ini bukan kode yang dijalankan — hanya tampilan teks bergaya kode.
 * Cara update: edit string `code` di bawah.
 */

import { Code } from 'astro:components';

// Isi kode TypeScript yang ditampilkan — ini string biasa, bukan kode yang dieksekusi
const code = `interface QAEngineer {
    name:            string;
    role:            string[];
    yearsExperience: string;
    location:        string;
};

interface Skills {
    qa:               string[];
    projectManagement: string[];
    designMultimedia: string[];
    webDigital:       string[];
    tools:            string[];
};

// --- Profile ---
const me: QAEngineer = {
    name:            'Rico Tri Wibowo',
    role:            ['QA Engineer', 'Project Manager', 'COO'],
    yearsExperience: '5+',
    location:        'Bandung, Indonesia',
};

// --- Skills by Category ---
const skills: Skills = {
    qa: [
        'Test Planning & Strategy',
        'Manual Testing',
        'API Testing (Postman)',
        'Regression Testing',
        'Bug Reporting & Triage',
        'Test Case Documentation',
        'UAT Coordination',
    ],
    projectManagement: [
        'Agile / Scrum',
        'Sprint Planning',
        'Stakeholder Management',
        'Risk Assessment',
        'JIRA / Trello',
    ],
    designMultimedia: [
        'Adobe Premiere Pro',
        'Adobe Photoshop',
        'Canva',
        'OBS Studio',
        'vMix',
    ],
    webDigital: [
        'HTML / CSS',
        'Basic JavaScript',
        'CMS Management',
        'SEO Basics',
        'Analytics',
    ],
    tools: [
        'Postman',
        'VS Code',
        'MS Office Suite',
        'Hopscotch',
        'Google Workspace',
    ],
};

// --- Career Stats ---
const stats = {
    yearsExperience:   '5+',
    projectsDelivered: '15+',
    testCasesWritten:  '300+',
};

// --- Contact ---
const contact = (channel: string): string => {
    switch (channel) {
        case 'email':     return 'ricobowo10@gmail.com';
        case 'linkedIn':  return 'linkedin.com/in/rico-tri-wibowo';
        case 'instagram': return 'instagram.com/ricobowo_';
        case 'twitter':   return 'twitter.com/ricobowo_';
        default:          return 'See social links.';
    }
};
`;
---

<!-- Blok kode TypeScript dengan syntax highlighting Shiki -->
<Code
    code={code}
    lang="ts"
    wrap={true}
/>

<style is:global>

    /* Hilangkan warna latar dari blok kode — pakai latar panel (navy) */
    pre.astro-code {
        @apply bg-transparent !important;
    }

    /* Setiap baris kode dihitung dan diberi nomor baris di kiri */
    pre.astro-code code {
        @apply block;
        counter-reset: step;
        counter-increment: step 0;
    }

    pre.astro-code code .line {
        @apply relative;
    }

    /* Nomor baris — dirender sebagai ::before setiap elemen .line */
    pre.astro-code code .line::before {
        content: counter(step);
        counter-increment: step;
        @apply text-gray-600 pr-4 select-none;
    }

</style>
