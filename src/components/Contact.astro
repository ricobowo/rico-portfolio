---
import Socials from './Socials.astro';
---

<div>

    <!-- Terminal widget -->
    <div class="mt-6 bg-navy-card rounded-lg p-4 border border-gray-700 text-xs font-mono">

        <div class="flex items-center mb-2">
            <span class="text-primary mr-2">$</span>
            <span class="text-gray-100">rico --connect</span>
        </div>

        <div class="mt-2 text-muted leading-relaxed">
            Initializing connection...<br />
            QA Engineer & PM available.<br />
            Open to new opportunities.
        </div>

    </div>

    <!-- CV Download button -->
    <a
        href="/cv/Rico_Tri_Wibowo_CV.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full mt-4 px-4 py-2.5 text-sm font-medium border border-primary text-primary rounded-lg hover:bg-primary hover:text-white transition-all duration-150">
        <svg fill="none" height="16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="16" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download CV
    </a>

    <!-- Social Links -->
    <Socials />

</div>
