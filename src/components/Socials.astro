---
/**
 * Socials.astro — Baris tombol ikon sosial media
 *
 * Menampilkan tombol-tombol kotak kecil, satu per platform.
 * Setiap tombol adalah link <a> biasa ke profil yang bersangkutan.
 *
 * Cara menambah platform baru:
 *   1. Tambahkan entry baru ke array `socials` di bawah
 *   2. Tambahkan case SVG yang sesuai di SocialIcon.astro
 *
 * Icon yang tersedia: 'linkedIn' | 'email' | 'twitter' | 'instagram' | 'github'
 */

import SocialIcon from './SocialIcon.astro';

// Tipe data untuk satu entri sosial media
interface Social {
    icon:   'linkedIn' | 'email' | 'twitter' | 'instagram' | 'github'; // Nama ikon — harus ada di SocialIcon.astro
    link:   string;   // URL tujuan atau mailto: untuk email
    title?: string;   // Teks tooltip saat kursor diarahkan ke tombol
}

// Daftar sosial media — ubah URL di sini untuk ganti tujuan link
const socials: Social[] = [{
    icon:  'linkedIn',
    link:  'https://www.linkedin.com/in/rico-tri-wibowo',
    title: 'LinkedIn — Rico Tri Wibowo'
}, {
    icon:  'email',
    link:  'mailto:ricobowo10@gmail.com',
    title: 'Email — ricobowo10@gmail.com'
}, {
    icon:  'twitter',
    link:  'https://twitter.com/ricobowo_',
    title: 'Twitter / X'
}, {
    icon:  'instagram',
    link:  'https://instagram.com/ricobowo_',
    title: 'Instagram'
}];
---

<!-- Baris tombol sosial media -->
<!-- justify-between agar tombol tersebar merata ke seluruh lebar panel -->
<div class="flex flex-wrap gap-3 mt-4 justify-between">

    {socials.map(social =>

        <!-- Tombol ikon individual — kotak dengan sudut membulat -->
        <!-- Link email pakai _self (buka di tab yang sama), link lain pakai _blank -->
        <a
            href={social.link}
            target={social.link.startsWith('mailto') ? '_self' : '_blank'}
            title={social.title}
            rel="noopener noreferrer"
            class="flex items-center justify-center w-10 h-10 rounded-lg bg-navy-card text-gray-100 transition-all duration-150 border border-gray-700 hover:bg-primary hover:border-primary hover:-translate-y-0.5">

            <!-- Ikon SVG dipilih oleh SocialIcon.astro berdasarkan prop `icon` -->
            <SocialIcon icon={social.icon} />

        </a>

    )}

</div>
