---
import SocialIcon from './SocialIcon.astro';

interface Social {
    icon: 'linkedIn' | 'email' | 'twitter' | 'instagram' | 'github';
    link: string;
    title?: string;
}

const socials: Social[] = [{
    icon: 'linkedIn',
    link: 'https://www.linkedin.com/in/rico-tri-wibowo',
    title: 'LinkedIn — Rico Tri Wibowo'
}, {
    icon: 'email',
    link: 'mailto:ricobowo10@gmail.com',
    title: 'Email — ricobowo10@gmail.com'
}, {
    icon: 'twitter',
    link: 'https://twitter.com/ricobowo',
    title: 'Twitter / X'
}, {
    icon: 'instagram',
    link: 'https://instagram.com/ricobowo',
    title: 'Instagram'
}];
---

<div class="flex flex-wrap gap-3 mt-4 justify-between">

    {socials.map(social =>
        <a
            href={social.link}
            target={social.link.startsWith('mailto') ? '_self' : '_blank'}
            title={social.title}
            rel="noopener noreferrer"
            class="flex items-center justify-center w-10 h-10 rounded-lg bg-navy-card text-gray-100 transition-all duration-150 border border-gray-700 hover:bg-primary hover:border-primary hover:-translate-y-0.5">
            <SocialIcon icon={social.icon} />
        </a>
    )}

</div>
