---
/**
 * ContentExperience.astro — Tab "experience.json": Riwayat pekerjaan
 *
 * Menampilkan 5 posisi kerja Rico dalam kartu yang bisa di-hover.
 * Setiap kartu berisi: judul, perusahaan, periode, badge tipe, dan poin-poin kerja.
 *
 * Badge tipe:
 *   QA    = biru accent | PM    = hijau
 *   Ops   = kuning      | Admin = abu-abu
 *
 * Cara menambah pengalaman baru: tambahkan objek baru ke array `experiences`.
 */

// Tipe data untuk satu entri pengalaman kerja
interface Experience {
    title:    string;
    company:  string;
    period:   string;
    type:     'QA' | 'PM' | 'Ops' | 'Admin';
    bullets:  string[];
};

// Diurutkan dari yang terbaru ke yang terlama
const experiences: Experience[] = [{
    title:   'QA Engineer',
    company: 'Rolling Glory',
    period:  'Nov 2024 – Present',
    type:    'QA',
    bullets: [
        'Conduct manual and API testing for mobile & web applications',
        'Write and maintain test cases, bug reports, and QA documentation',
        'Coordinate UAT sessions with clients and internal teams',
        'Tools: Postman, JIRA, Hopscotch, VS Code',
    ],
}, {
    title:   'Administration Staff — Communication Studies',
    company: 'Telkom University',
    period:  'Oct 2024 – Present',
    type:    'Admin',
    bullets: [
        'Manage academic and administrative documentation for the department',
        'Support faculty-student communication and scheduling workflows',
        'Coordinate departmental events and operational activities',
    ],
}, {
    title:   'Chief Operating Officer',
    company: 'PSI Indonesia',
    period:  'Jul 2023 – Present',
    type:    'Ops',
    bullets: [
        'Oversee day-to-day operations across all departments',
        'Lead project planning and cross-functional team coordination',
        'Drive process improvement initiatives and operational efficiency',
        'Manage vendor relationships and stakeholder communication',
    ],
}, {
    title:   'Administration Staff — Research & Community Service',
    company: 'Telkom University',
    period:  'Feb 2021 – Nov 2024',
    type:    'Admin',
    bullets: [
        'Administered documentation and reporting for research programs',
        'Coordinated community service initiatives and outreach events',
        'Maintained data accuracy across institutional databases',
    ],
}, {
    title:   'Junior Project Manager',
    company: 'Rolling Glory',
    period:  'Sep 2019 – Nov 2020',
    type:    'PM',
    bullets: [
        'Managed project timelines, scope, and deliverables for 6+ products',
        'Facilitated daily standups and sprint planning sessions',
        'Served as the primary liaison between the dev team and clients',
        'Delivered mobile and web projects on schedule and within scope',
    ],
}];

// Warna badge per tipe — teks + border
const typeColor: Record<string, string> = {
    QA:    'text-primary border-primary',
    PM:    'text-green-400 border-green-400',
    Ops:   'text-yellow-400 border-yellow-400',
    Admin: 'text-muted border-gray-600',
};
---

<!-- Daftar kartu pengalaman kerja, tersusun vertikal -->
<div class="flex flex-col gap-5">

    {experiences.map(exp => (

        <!-- Kartu satu pengalaman — border berubah ke biru saat hover -->
        <div class="border border-gray-700 rounded-lg p-5 bg-navy-card hover:border-primary transition-colors duration-200">

            <!-- Baris atas: judul + perusahaan (kiri) | badge + periode (kanan) -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-3">

                <div>
                    <h3 class="font-semibold text-gray-100 text-base">{exp.title}</h3>
                    <p class="text-sm text-primary mt-0.5">{exp.company}</p>
                </div>

                <div class="flex items-center gap-2 shrink-0">
                    <!-- Badge kategori warna berbeda per tipe -->
                    <span class={`text-xs border rounded px-2 py-0.5 font-mono ${typeColor[exp.type]}`}>
                        {exp.type}
                    </span>
                    <span class="text-xs text-muted font-mono">{exp.period}</span>
                </div>

            </div>

            <!-- Poin-poin pekerjaan -->
            <ul class="flex flex-col gap-1">
                {exp.bullets.map(b => (
                    <li class="text-sm text-muted flex gap-2">
                        <span class="text-primary mt-0.5 shrink-0">›</span>
                        {b}
                    </li>
                ))}
            </ul>

        </div>

    ))}

</div>
