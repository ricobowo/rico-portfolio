---
/**
 * ContentProjects.astro — Tab "projects.md": Daftar proyek portofolio
 *
 * Menampilkan 6 proyek Rico dalam grid dua kolom.
 * Setiap kartu berisi: nama, badge kategori, deskripsi, metrics, dan tag.
 *
 * Badge: QA Testing = biru | Project Management = hijau
 *
 * Cara menambah proyek baru: tambahkan objek ke array `projects`.
 */

// Tipe data untuk satu proyek
interface Project {
    name:        string;
    description: string;
    category:    'QA Testing' | 'Project Management';
    metrics?:    string;
    tags:        string[];
};

// 4 proyek QA + 2 proyek PM
const projects: Project[] = [{
    name:        'B7 Supersales',
    category:    'QA Testing',
    description: 'End-to-end QA for a B2B sales platform — test planning, regression cycles, and API validation to ensure stability across every release.',
    metrics:     '50+ test cases · 3 release cycles',
    tags:        ['Manual Testing', 'API Testing', 'Regression'],
}, {
    name:        'Bebeclub',
    category:    'QA Testing',
    description: 'Quality assurance for a parenting community mobile app. Managed functional, UI, and device compatibility testing across Android and iOS.',
    metrics:     'Android & iOS · UAT coordination',
    tags:        ['Mobile Testing', 'UAT', 'Bug Reporting'],
}, {
    name:        'Treasury',
    category:    'QA Testing',
    description: 'QA Engineer for a financial management application. Focused on data integrity testing, edge-case coverage, and security validation.',
    metrics:     'Financial flows · Edge-case coverage',
    tags:        ['Functional Testing', 'Security', 'Postman'],
}, {
    name:        'TADA Spin Wheel',
    category:    'QA Testing',
    description: 'Tested a loyalty rewards feature (spin wheel mechanic) — validating randomness logic, reward distribution, and error handling under load.',
    metrics:     'Reward logic · Load scenario testing',
    tags:        ['Feature Testing', 'Logic Validation', 'API'],
}, {
    name:        'RS Mitra Keluarga',
    category:    'Project Management',
    description: 'Led the delivery of a hospital information system — coordinating vendor, hospital management, and dev team from scoping to go-live.',
    metrics:     'On-time delivery · 4-month timeline',
    tags:        ['Agile', 'Stakeholder Mgmt', 'Scrum'],
}, {
    name:        'Morinaga Platinum',
    category:    'Project Management',
    description: 'Project Manager for a consumer brand digital campaign. Managed timeline, vendor deliverables, and content production across multiple channels.',
    metrics:     'Multi-channel · 3 vendor teams',
    tags:        ['Project Planning', 'Vendor Mgmt', 'Campaign'],
}];

// Warna badge per kategori
const categoryColor: Record<string, string> = {
    'QA Testing':         'text-primary border-primary',
    'Project Management': 'text-green-400 border-green-400',
};
---

<!-- Grid proyek — 1 kolom di mobile, 2 kolom di desktop -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">

    {projects.map(project => (

        <!-- Kartu proyek — border berubah ke biru saat hover -->
        <div class="flex flex-col border border-gray-700 rounded-lg p-4 bg-navy-card hover:border-primary transition-colors duration-200">

            <!-- Nama proyek + badge kategori -->
            <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="text-base font-semibold text-gray-100">{project.name}</h3>
                <span class={`text-xs border rounded px-2 py-0.5 shrink-0 font-mono ${categoryColor[project.category]}`}>
                    {project.category === 'QA Testing' ? 'QA' : 'PM'}
                </span>
            </div>

            <!-- Deskripsi — flex-grow agar semua kartu setinggi sejajar -->
            <p class="text-sm text-muted leading-relaxed flex-grow">{project.description}</p>

            <!-- Metrics — angka kunci dalam font mono biru -->
            {project.metrics && (
                <p class="text-xs text-primary mt-3 font-mono">{project.metrics}</p>
            )}

            <!-- Tag label -->
            <div class="flex flex-wrap gap-1.5 mt-3">
                {project.tags.map(tag => (
                    <span class="text-xs border border-gray-700 text-muted rounded px-2 py-0.5">{tag}</span>
                ))}
            </div>

        </div>

    ))}

</div>
