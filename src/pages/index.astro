---
/**
 * index.astro — Halaman utama (satu-satunya halaman di website ini)
 *
 * Layout terbagi dua panel:
 *   Kiri  (2/5 lebar): Kartu profil + widget terminal + tombol CV + ikon sosial
 *   Kanan (4/5 lebar): Area tab — bisa diklik untuk ganti konten
 *
 * Sistem tab bekerja murni dengan CSS (tanpa JavaScript).
 * Caranya: setiap tab punya <input type="radio"> tersembunyi.
 * Saat diklik, CSS selector :checked menampilkan konten yang sesuai.
 */

import Layout from '../layouts/Layout.astro';

// Komponen panel kiri
import Profile from '../components/Profile.astro';
import Contact from '../components/Contact.astro';

// Komponen tombol tab (label HTML)
import ContentLink from '../components/ContentLink.astro';

// Komponen isi setiap tab
import ContentExperience from '../components/ContentExperience.astro'; // Tab 1: experience.ts
import ContentProjects   from '../components/ContentProjects.astro';   // Tab 2: projects.md
import ContentAbout      from '../components/ContentAbout.astro';       // Tab 3: about.ts
import ContentReadme     from '../components/ContentReadme.astro';      // Tab 4: README.md
---

<Layout>

    <!-- ========================================================
         Pembungkus utama kartu
         Lebar maksimal 7xl untuk layar besar
         Border + shadow untuk kesan kedalaman
         ======================================================== -->
    <main class="flex flex-col md:flex-row w-full max-w-full md:max-w-7xl border border-gray-700 rounded-2xl overflow-hidden shadow-2xl relative bg-navy">

        <!-- ====================================================
             PANEL KIRI — Profil, terminal, tombol CV, ikon sosial
             Lebar 2/5 di desktop, lebar penuh di mobile
             ==================================================== -->
        <div class="p-8 md:p-6 pb-14 flex flex-col justify-between w-full md:w-2/5 border-b md:border-b-0 md:border-r border-gray-700">
            <Profile />
            <Contact />
        </div>

        <!-- ====================================================
             PANEL KANAN — Area tab dengan konten yang bisa diganti
             Lebar 4/5 di desktop, lebar penuh di mobile
             ==================================================== -->
        <div class="w-full md:w-4/5 p-0">

            <!-- Pembungkus dalam yang bisa di-scroll, tinggi 90vh -->
            <div class="min-h-full h-[90vh] flex flex-col overflow-y-scroll">

                <!-- Sistem tab (murni CSS, tanpa JavaScript)
                     Radio input tersembunyi mengontrol tab mana yang aktif -->
                <div class="tab-controls">

                    <!-- Input radio — satu per tab, disembunyikan lewat class .tab-radio -->
                    <input type="radio" id="tab1" name="tabs" class="tab-radio" checked /> <!-- experience.ts -->
                    <input type="radio" id="tab2" name="tabs" class="tab-radio" />          <!-- projects.md     -->
                    <input type="radio" id="tab3" name="tabs" class="tab-radio" />          <!-- about.ts        -->
                    <input type="radio" id="tab4" name="tabs" class="tab-radio" />          <!-- README.md       -->

                    <!-- ==========================================
                         Bar tab — menempel di atas saat scroll
                         Setiap ContentLink merender <label for="tabN">
                         ========================================== -->
                    <div class="flex bg-navy border-b border-gray-700 sticky top-0 z-10 overflow-x-auto">
                        <ContentLink contentId="tab1" contentName="experience.ts" />
                        <ContentLink contentId="tab2" contentName="projects.md" />
                        <ContentLink contentId="tab3" contentName="about.ts" />
                        <ContentLink contentId="tab4" contentName="README.md" />
                    </div>

                    <!-- ==========================================
                         Panel isi setiap tab
                         Tampil/sembunyi lewat CSS :checked selector
                         ========================================== -->
                    <div class="p-6 flex-grow overflow-y-auto bg-navy">

                        <!-- Tab 1: Riwayat pekerjaan -->
                        <div id="content1" class="tab-content">
                            <ContentExperience />
                        </div>

                        <!-- Tab 2: Proyek portofolio -->
                        <div id="content2" class="tab-content">
                            <ContentProjects />
                        </div>

                        <!-- Tab 3: Skill sebagai kode TypeScript -->
                        <div id="content3" class="tab-content">
                            <ContentAbout />
                        </div>

                        <!-- Tab 4: Ringkasan profesional gaya README -->
                        <div id="content4" class="tab-content">
                            <ContentReadme />
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </main>


</Layout>

<style is:global>

    /* Sembunyikan input radio — hanya dipakai untuk logika CSS :checked */
    .tab-radio {
        @apply absolute opacity-0 pointer-events-none;
    }

    /* Default: semua isi tab disembunyikan */
    .tab-content {
        @apply hidden opacity-0;
        transition: opacity 0.3s ease-in-out;
    }

    /* Default: semua label tab tidak punya garis bawah aktif */
    .tab-link {
        @apply border-b-2 border-transparent bg-transparent;
        transition: background-color 0.2s ease-in-out;
    }

    /* Tab 1 (experience.ts) — tampilkan konten + tandai label saat dipilih */
    #tab1:checked ~ * #content1 { @apply block opacity-100; }
    #tab1:checked ~ .flex .tab-link:nth-child(1) { @apply border-b-2 border-b-primary; }

    /* Tab 2 (projects.md) — tampilkan konten + tandai label saat dipilih */
    #tab2:checked ~ * #content2 { @apply block opacity-100; }
    #tab2:checked ~ .flex .tab-link:nth-child(2) { @apply border-b-2 border-b-primary; }

    /* Tab 3 (about.ts) — tampilkan konten + tandai label saat dipilih */
    #tab3:checked ~ * #content3 { @apply block opacity-100; }
    #tab3:checked ~ .flex .tab-link:nth-child(3) { @apply border-b-2 border-b-primary; }

    /* Tab 4 (README.md) — tampilkan konten + tandai label saat dipilih */
    #tab4:checked ~ * #content4 { @apply block opacity-100; }
    #tab4:checked ~ .flex .tab-link:nth-child(4) { @apply border-b-2 border-b-primary; }

</style>
